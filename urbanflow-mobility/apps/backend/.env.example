# Database — Supabase (projet "urbanflow", eu-west-3)
# Mot de passe DB visible une seule fois à la création, sinon Dashboard > Project Settings > Database > Reset password.

# Connexion poolée (PgBouncer, port 6543) — utilisée par l'appli au runtime.
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connexion directe (port 5432, PAS de pgbouncer) — utilisée UNIQUEMENT par `prisma migrate`.
# Le moteur de migration Prisma s'appuie sur des prepared statements que le pooler
# transactionnel (6543) ne supporte pas correctement : cf. directUrl dans schema.prisma.
DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@db.<project-ref>.supabase.co:5432/postgres"

# Redis — si tu déploies avec docker-compose.prod.yml, cette variable est déjà fixée à
# redis://redis:6379 par le bloc `environment:` du service backend (elle prime sur
# .env.production) : PAS BESOIN de la renseigner ici dans ce cas.
# Sinon (déploiement hors Docker Compose), renseigne l'URL de ton Redis.
REDIS_URL=""

# JWT — générer des secrets aléatoires dédiés à la prod (ne jamais réutiliser ceux de dev)
JWT_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# IDFM PRIM API
NAVITIA_BASE_URL="https://prim.iledefrance-mobilites.fr/marketplace/v2/navitia"
NAVITIA_API_KEY=""

OPENWEATHER_API_KEY=""

# App
PORT=3001
NODE_ENV="production"

# Origine autorisée en CORS (voir app.enableCors dans main.ts) — le domaine du
# frontend Vercel déployé. Sans cette variable correctement définie, le navigateur
# bloque tous les appels API du frontend en erreur CORS.
CORS_ORIGIN="https://urbanflow.poutoo.dev"
