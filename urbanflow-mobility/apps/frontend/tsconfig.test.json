{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["jest", "node", "@testing-library/jest-dom"],
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "noUncheckedIndexedAccess": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "jest.setup.ts"],
  "exclude": ["node_modules"]
}
